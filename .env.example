NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase's newer publishable key name is also supported.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase's newer server-side secret key name is also supported.
SUPABASE_SECRET_KEY=

# Select "auto", "demo", or a concrete provider adapter name.
MARKET_DATA_PROVIDER=auto
NEWS_DATA_PROVIDER=auto

# Market/news providers. For scheduled collection, add these as Supabase Edge
# Function secrets for collect-market-data. Do not expose them to frontend code.
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=

# CRON_SECRET is required by the Supabase Edge Function and Supabase Cron.
CRON_SECRET=

# Deployment metadata for normal app routes.
APP_URL=http://localhost:4173

# Optional error monitoring.
SENTRY_DSN=
